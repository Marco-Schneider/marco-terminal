---
const projects = [
    {
        name: 'Inventra',
        desc: 'Inventory management system with real-time sync and multi-warehouse support.',
        tags: ['Next.js', 'Postgres', 'Redis'],
        url: '#',
    },
    {
        name: 'Flowboard',
        desc: 'Kanban-style project tracker with live collaboration via WebSockets.',
        tags: ['React', 'Node', 'Socket.io'],
        url: '#',
    },
    {
        name: 'DataPipe CLI',
        desc: 'Open-source ETL tool for moving data between cloud databases with zero config.',
        tags: ['Go', 'AWS', 'GCP'],
        url: '#',
    },
    {
        name: 'Authly',
        desc: 'Drop-in OAuth2 + JWT authentication service for Node microservices.',
        tags: ['TypeScript', 'Docker'],
        url: '#',
    },
];
---

<section id="projects" class="section">
    <p class="section-label">Selected projects</p>
    <div class="grid">
        {
            projects.map((p) => (
                <a href={p.url} class="card">
                    <h3>{p.name}</h3>
                    <p>{p.desc}</p>
                    <div class="tags">
                        {p.tags.map((t) => (
                            <span class="tag">{t}</span>
                        ))}
                    </div>
                </a>
            ))
        }
    </div>
</section>

<style>
    .section {
        padding: 40px 0;
        border-bottom: 0.5px solid var(--border);
    }
    .section-label {
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--teal-400);
        margin-bottom: 20px;
    }
    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }
    .card {
        display: block;
        background: var(--teal-50);
        border: 0.5px solid var(--teal-100);
        border-radius: 12px;
        padding: 20px 22px;
        transition: border-color 0.15s;
    }
    .card:hover {
        border-color: var(--teal-400);
        color: inherit;
    }
    .card h3 {
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 6px;
        color: var(--teal-800);
    }
    .card p {
        font-size: 12px;
        color: var(--teal-600);
        line-height: 1.6;
        margin-bottom: 12px;
    }
    .tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }
    .tag {
        font-size: 11px;
        background: white;
        border: 0.5px solid var(--teal-100);
        padding: 2px 8px;
        border-radius: 99px;
        color: var(--teal-600);
    }
</style>
