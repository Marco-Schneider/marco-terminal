---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="About | João Silva"
    description="A bit more about me — how I got here, what I care about, and how I work."
>
    <article class="about">
        <header class="about-header">
            <p class="eyebrow">About</p>
            <h1>Hey, I'm Marco.</h1>
        </header>

        <div class="about-body">
            <section class="about-section">
                <h2>Background</h2>
                <p>
                    I'm a full stack developer based in Curitiba, Brazil. I've
                    spent the last several years building web products — from
                    early-stage startups to established SaaS companies — working
                    across the entire stack.
                </p>
                <p>
                    I gravitate toward problems at the intersection of product
                    and engineering: systems that need to scale, interfaces that
                    need to feel fast, and codebases that people actually want
                    to work in.
                </p>
            </section>

            <section class="about-section">
                <h2>How I work</h2>
                <p>
                    I care about shipping things that work reliably. That means
                    thinking carefully about data models before writing a line
                    of UI, writing tests for the parts that matter, and being
                    honest when something is more complex than it first
                    appeared.
                </p>
                <p>
                    I like small, focused teams where everyone has context. I
                    write a lot — proposals, postmortems, doc comments — because
                    I think clear writing leads to clearer thinking.
                </p>
            </section>

            <section class="about-section">
                <h2>Currently</h2>
                <p>
                    Available for freelance and consulting engagements.
                    Particularly interested in early-stage product work and
                    developer tooling projects.
                </p>
                <p>
                    <a href="mailto:joao@yoursite.dev" class="cta-link"
                        >Get in touch →</a
                    >
                </p>
            </section>

            <section class="about-section">
                <h2>Elsewhere</h2>
                <ul class="links-list">
                    <li>
                        <a href="https://github.com" target="_blank">GitHub</a> —
                        open source work and side projects
                    </li>
                    <li>
                        <a href="https://linkedin.com" target="_blank"
                            >LinkedIn</a
                        > — professional history
                    </li>
                    <li>
                        <a href="https://x.com" target="_blank">X / Twitter</a> —
                        occasional thoughts
                    </li>
                    <li><a href="/rss.xml">RSS</a> — subscribe to the blog</li>
                </ul>
            </section>
        </div>
    </article>
</BaseLayout>

<style>
    .about {
        padding: 52px 0;
        max-width: 600px;
    }
    .eyebrow {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--teal-400);
        margin-bottom: 10px;
    }
    .about-header h1 {
        font-size: 32px;
        font-weight: 500;
        margin-bottom: 40px;
        padding-bottom: 32px;
        border-bottom: 0.5px solid var(--border);
    }
    .about-body {
        display: flex;
        flex-direction: column;
        gap: 36px;
    }
    .about-section h2 {
        font-size: 13px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--teal-600);
        margin-bottom: 14px;
    }
    .about-section p {
        font-size: 15px;
        color: var(--text-secondary);
        line-height: 1.8;
        margin-bottom: 12px;
    }
    .cta-link {
        color: var(--teal-600);
        font-weight: 500;
    }
    .cta-link:hover {
        color: var(--teal-800);
    }
    .links-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
        font-size: 15px;
        color: var(--text-secondary);
    }
    .links-list a {
        color: var(--teal-600);
        font-weight: 500;
    }
    .links-list a:hover {
        color: var(--teal-800);
    }
</style>
