---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Blog | João Silva" description="Writing about web development, architecture, and tooling.">
  <section class="blog-index">
    <h1>Blog</h1>
    <div class="posts">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post">
          <div class="post-left">
            <span class="cat">{post.data.category}</span>
            <span class="title">{post.data.title}</span>
            <span class="desc">{post.data.description}</span>
          </div>
          <span class="date">
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-index { padding: 48px 0; }
  h1 { font-size: 28px; font-weight: 500; margin-bottom: 32px; }
  .posts { display: flex; flex-direction: column; }
  .post {
    display: flex; justify-content: space-between; align-items: flex-start;
    padding: 18px 0; border-bottom: 0.5px solid var(--border); gap: 24px;
  }
  .post:first-child { border-top: 0.5px solid var(--border); }
  .post:hover .title { color: var(--teal-600); }
  .post-left { display: flex; flex-direction: column; gap: 5px; }
  .cat {
    display: inline-block; font-size: 10px; font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.07em;
    background: var(--teal-50); color: var(--teal-800);
    padding: 2px 8px; border-radius: 99px;
  }
  .title { font-size: 15px; font-weight: 500; }
  .desc { font-size: 13px; color: var(--text-secondary); }
  .date { font-size: 12px; color: var(--text-muted); white-space: nowrap; padding-top: 2px; }
</style>